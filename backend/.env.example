# Backend environment variables
# Copy to .env and fill in real values

# --- App ---
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-too
FLASK_ENV=production
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Database (Render provides DATABASE_URL automatically) ---
# When deploying to Render, set DATABASE_URL to the external Postgres URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/congestion_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=congestion_db

# --- Redis (optional; Render provides REDIS_URL) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=SimpleCache

# --- Rate limiting ---
RATELIMIT_DEFAULT=200 per hour

# --- CORS (comma-separated list of allowed origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Kaggle (for downloading NF-UNSW-NB15-v3) ---
KAGGLE_API_TOKEN=your_kaggle_token_here
KAGGLE_DATASET=ndayisabae/nf-unsw-nb15-v3

# --- JWT expiry ---
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
