# Render-specific environment variables (DO NOT COMMIT REAL VALUES)
# Copy to .env.render and fill in real values

# Database (auto-configured by Render)
DATABASE_URL=postgresql://user:pass@host:5432/db

# Redis (auto-configured by Render)
REDIS_URL=redis://host:6379/0

# Secrets (auto-generated by Render)
SECRET_KEY=
JWT_SECRET_KEY=

# CORS
CORS_ORIGINS=https://your-frontend.onrender.com

# Kaggle (set manually)
KAGGLE_API_TOKEN=
KAGGLE_DATASET=ndayisabae/nf-unsw-nb15-v3
